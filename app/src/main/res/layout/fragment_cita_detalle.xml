<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="88dp">

            <!-- Toolbar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="96dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="40dp"
                android:paddingHorizontal="16dp">

                <ImageButton
                    android:id="@+id/btnVolver"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_back"
                    app:tint="#FFFFFF" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:letterSpacing="0.1"
                    android:text="DETALLE CITA"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Info cita -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvTipo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#CC0000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvMoto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvCliente"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/tvFechaHora"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DESCRIPCIÓN DEL CLIENTE"
                    android:textColor="#CC0000"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="#2A2A2A"
                    android:layout_marginBottom="24dp"/>

                <!-- PRESUPUESTO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PRESUPUESTO"
                    android:textColor="#CC0000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"/>

                <!-- Checks mantenimiento solo visible en MANTENIMIENTO/ mecanico -->
                <LinearLayout
                    android:id="@+id/layoutMantenimientoFijos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tareas de mantenimiento"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>

                    <CheckBox
                        android:id="@+id/cbFiltroAire"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Filtro de aire"
                        android:textColor="#FFFFFF"
                        android:buttonTint="@color/honda_red"/>

                    <CheckBox
                        android:id="@+id/cbBujias"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Bujías"
                        android:textColor="#FFFFFF"
                        android:buttonTint="@color/honda_red"/>

                    <CheckBox
                        android:id="@+id/cbAceite"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cambio de aceite"
                        android:textColor="#FFFFFF"
                        android:buttonTint="@color/honda_red"/>

                    <CheckBox
                        android:id="@+id/cbFrenos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pastillas de freno"
                        android:textColor="#FFFFFF"
                        android:buttonTint="@color/honda_red"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#333333"
                        android:layout_marginVertical="12dp"/>
                </LinearLayout>

                <!-- Lista de items dinámica -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="8dp"/>

                <!-- Añadir item solo mecanico en BORRADOR -->
                <Button
                    android:id="@+id/btnAnadirItem"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="+ Añadir concepto"
                    android:backgroundTint="#333333"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"/>

                <LinearLayout
                    android:id="@+id/layoutTotales"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:background="#2A2A2A"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Subtotal"
                            android:textColor="#AAAAAA"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvSubtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="IVA (21%)"
                            android:textColor="#AAAAAA"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvIva"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#444"
                        android:layout_marginVertical="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="TOTAL"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/tvTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#CC0000"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/btnEnviarPresupuesto"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="ENVIAR PRESUPUESTO AL CLIENTE"
                        android:backgroundTint="@color/honda_red"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btnEntregar"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="ENTREGAR MOTO"
                        android:backgroundTint="#2E7D32"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btnConfirmarRecogida"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="CONFIRMAR RECOGIDA"
                        android:backgroundTint="#1976D2"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:visibility="gone"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:id="@+id/layoutClienteAccion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <Button
                            android:id="@+id/btnAprobar"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:text="APROBAR"
                            android:backgroundTint="#2E7D32"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:layout_marginEnd="8dp"/>

                        <Button
                            android:id="@+id/btnRechazar"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:text="RECHAZAR"
                            android:backgroundTint="#C62828"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutAccionesCita"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/btnModificarCita"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="MODIFICAR CITA"
                        android:backgroundTint="#FF9800"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btnCancelarCita"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="CANCELAR CITA"
                        android:backgroundTint="#C62828"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <Button
                        android:id="@+id/btnEliminarCita"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="ELIMINAR CITA"
                        android:backgroundTint="#333333"
                        android:textColor="#FF4444"
                        android:textStyle="bold"
                        android:visibility="gone"/>
                </LinearLayout>


            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>